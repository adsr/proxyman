{
  "name": "ProxyMan",
  "description": "No-nonsense proxy manager and switcher",
  "version": "1.1.0",
  "homepage_url": "https://github.com/adsr/proxyman",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "options_page": "options.html",
  "permissions": [
    "proxy",
    "storage"
  ],
  "background": {
    "service_worker": "worker.js",
    "type": "module"
  }
}
